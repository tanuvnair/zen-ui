{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "./dist",
    // Emit dist/index.d.ts, not dist/src/index.d.ts. Without this, tsc infers
    // rootDir from the inputs and keeps the src/ prefix, so the declarations
    // land at dist/src/ while package.json's "types" points at dist/ — and
    // consumers get NO types at all. Both other bindings shipped exactly that.
    // Mirrors preserveModulesRoot:"src".
    "rootDir": "./src",
    "preserveWatchOutput": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*Demo.ts",
    "src/app.ts",
    "src/main.ts"
  ]
}
