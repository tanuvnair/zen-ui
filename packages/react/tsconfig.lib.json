{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    // Enable declaration file generation
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    // Output directory for compiled files and declarations
    "outDir": "./dist",
    // Emit dist/index.d.ts, not dist/src/index.d.ts. Without this, tsc infers
    // rootDir from the inputs and keeps the src/ prefix, so the declarations
    // landed at dist/src/ while package.json's "types" pointed at dist/ — and
    // consumers got NO types at all. It survived because emptyOutDir:false kept
    // a stale dist/index.d.ts alive on machines that had once built it; a fresh
    // clone never had one. Mirrors preserveModulesRoot:"src" in the vite config.
    "rootDir": "./src",
    // Preserve module structure for better tree-shaking
    "preserveWatchOutput": true,
    // Relax unused variable checks for library build
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*Demo.tsx",
    "src/App.tsx",
    "src/main.tsx"
  ]
}
