{
  "name": "@algorisys/zen-ui",
  "version": "2.1.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": {
      "import": "./dist/style.css",
      "types": "./dist/styles.d.ts",
      "default": "./dist/style.css"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/algorisys/zen-ui.git"
  },
  "homepage": "https://github.com/algorisys/zen-ui",
  "publishConfig": {
    "@algorisys:registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "dev": "vite --config vite.config.demo.ts",
    "build": "tsc -b && vite build --config vite.config.demo.ts",
    "build-server": "tsc -p tsconfig-server.json",
    "build:lib": "vite build --config vite.config.lib.ts && npm run build:types && cp src/styles.d.ts dist/styles.d.ts",
    "build:types": "tsc --project tsconfig.lib.json --emitDeclarationOnly",
    "publish:lib": "npm run build:lib && npm publish",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "preview": "vite preview --config vite.config.demo.ts",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist-demo"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^2.30.0",
    "input-otp": "^1.4.2",
    "lodash": "^4.17.21",
    "react-day-picker": "^10.0.1",
    "react-hook-form": "^7.45.0",
    "react-hot-toast": "^2.4.0",
    "react-router-dom": "^7.9.5",
    "tailwind-merge": "^3.6.0",
    "use-deep-compare-effect": "^1.8.1",
    "uuid": "^9.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.0.0",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@unocss/preset-uno": "^66.5.4",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "fastify": "^5.7.4",
    "gh-pages": "^6.3.0",
    "globals": "^16.4.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "unocss": "^66.5.4",
    "vite": "^7.1.7"
  }
}
