{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "./dist",
    // Emit dist/index.d.ts, not dist/src/index.d.ts — see the React binding's
    // tsconfig.lib.json for why this was silently broken. Mirrors
    // preserveModulesRoot:"src" in the vite config.
    "rootDir": "./src",
    "preserveWatchOutput": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*Demo.tsx",
    "src/App.tsx",
    "src/main.tsx"
  ]
}
