{
  "name": "@algorisys/zen-ui-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:all": "node scripts/dev-all.mjs",
    "check": "bun run check:types && bun run check:cn && bun run check:css-live && bun run check:mask && bun run check:color && bun run check:date-range && bun run check:chart && bun run check:pivot && bun run check:virtual-window && bun run check:nav && bun run check:parity && bun run check:release && bun run check:agent-guide",
    "gen:agent-guide": "bun run scripts/gen-agent-guide.ts",
    "check:agent-guide": "bun run scripts/gen-agent-guide.ts --check",
    "check:types": "tsc --project scripts/tsconfig.json",
    "check:cn": "bun run scripts/check-cn.ts",
    "check:css-live": "bun run scripts/check-css-live.ts",
    "check:mask": "bun run scripts/check-mask.ts",
    "check:color": "bun run scripts/check-color.ts",
    "check:date-range": "bun run scripts/check-date-range.ts",
    "check:chart": "bun run scripts/check-chart.ts",
    "check:pivot": "bun run scripts/check-pivot.ts",
    "check:virtual-window": "bun run scripts/check-virtual-window.ts",
    "check:nav": "bun run scripts/check-nav.ts",
    "check:parity": "bun run scripts/check-parity.ts",
    "check:release": "bun run scripts/check-release.ts",
    "check:package": "node scripts/check-package-artifacts.mjs",
    "check:size": "node scripts/check-bundle-size.mjs",
    "check:dist": "bun run build:lib && bun run build:lib:solid && bun run build:lib:vanilla && bun run build:lib:wc && bun run check:package && bun run check:size",
    "dev": "bun --filter @algorisys/zen-ui-react dev",
    "build": "bun --filter @algorisys/zen-ui-react build",
    "build:lib": "bun --filter @algorisys/zen-ui-react build:lib",
    "lint": "bun --filter @algorisys/zen-ui-react lint",
    "preview": "bun --filter @algorisys/zen-ui-react preview",
    "dev:solid": "bun --filter @algorisys/zen-ui-solid dev",
    "build:solid": "bun --filter @algorisys/zen-ui-solid build",
    "build:lib:solid": "bun --filter @algorisys/zen-ui-solid build:lib",
    "lint:solid": "bun --filter @algorisys/zen-ui-solid lint",
    "preview:solid": "bun --filter @algorisys/zen-ui-solid preview",
    "dev:landing": "bun --filter @algorisys/zen-ui-landing dev",
    "build:landing": "bun --filter @algorisys/zen-ui-landing build",
    "dev:vanilla": "bun --filter @algorisys/zen-ui-vanilla dev",
    "build:vanilla": "bun --filter @algorisys/zen-ui-vanilla build",
    "build:lib:vanilla": "bun --filter @algorisys/zen-ui-vanilla build:lib",
    "lint:vanilla": "bun --filter @algorisys/zen-ui-vanilla lint",
    "preview:vanilla": "bun --filter @algorisys/zen-ui-vanilla preview",
    "dev:wc": "bun --filter @algorisys/zen-ui-web-components dev",
    "build:wc": "bun --filter @algorisys/zen-ui-web-components build",
    "build:lib:wc": "bun --filter @algorisys/zen-ui-web-components build:lib",
    "lint:wc": "bun --filter @algorisys/zen-ui-web-components lint",
    "preview:wc": "bun --filter @algorisys/zen-ui-web-components preview"
  },
  "devDependencies": {
    "jodit": "^4.13.3",
    "playwright": "^1.61.1",
    "repograph": "github:algorisys-oss/repograph"
  }
}
