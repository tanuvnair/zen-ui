{
  "name": "@algorisys/zen-ui-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:all": "node scripts/dev-all.mjs",
    "check": "bun run check:cn && bun run check:mask && bun run check:color && bun run check:date-range && bun run check:chart && bun run check:nav",
    "check:cn": "bun run scripts/check-cn.ts",
    "check:mask": "bun run scripts/check-mask.ts",
    "check:color": "bun run scripts/check-color.ts",
    "check:date-range": "bun run scripts/check-date-range.ts",
    "check:chart": "bun run scripts/check-chart.ts",
    "check:nav": "bun run scripts/check-nav.ts",
    "dev": "bun --filter @algorisys/zen-ui-react dev",
    "build": "bun --filter @algorisys/zen-ui-react build",
    "build:lib": "bun --filter @algorisys/zen-ui-react build:lib",
    "lint": "bun --filter @algorisys/zen-ui-react lint",
    "preview": "bun --filter @algorisys/zen-ui-react preview",
    "dev:solid": "bun --filter @algorisys/zen-ui-solid dev",
    "build:solid": "bun --filter @algorisys/zen-ui-solid build",
    "build:lib:solid": "bun --filter @algorisys/zen-ui-solid build:lib",
    "lint:solid": "bun --filter @algorisys/zen-ui-solid lint",
    "preview:solid": "bun --filter @algorisys/zen-ui-solid preview",
    "dev:landing": "bun --filter @algorisys/zen-ui-landing dev",
    "build:landing": "bun --filter @algorisys/zen-ui-landing build"
  },
  "devDependencies": {
    "jodit": "^4.13.3",
    "playwright": "^1.61.1",
    "repograph": "github:algorisys-oss/repograph"
  }
}
